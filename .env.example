# ── Environment Variables ──────────────────────────────────────────────────

# DATABASE (dari Neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secret (buat string acak yang panjang)
JWT_SECRET=ganti-dengan-string-rahasia-yang-panjang

# URL Frontend (dari Vercel, untuk CORS)
FRONTEND_URL=https://nama-project-kamu.vercel.app
